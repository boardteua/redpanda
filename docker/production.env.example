# =============================================================================
# ПРОДАКШЕН — мінімальна безпека (обов’язково прочитайте перед заповненням)
# =============================================================================
# • Не комітьте цей файл з реальними значеннями. Копія: docker/production.env (у .gitignore).
# • Один пароль користувача БД: лише DB_PASSWORD (+ DB_USERNAME / DB_DATABASE). Compose підставляє
#   DB_PASSWORD у змінну образу mysql як MYSQL_PASSWORD (див. compose.yaml: ${DB_PASSWORD:-${MYSQL_PASSWORD:-…}}).
#   Якщо задано ОБИДВА — для образу mysql береться DB_PASSWORD; рядок MYSQL_PASSWORD у файлі ігнорується
#   compose і може бути «фантомним» іншим паролем → не додавайте MYSQL_PASSWORD, якщо вже є DB_PASSWORD.
#   Якщо випадково два різні значення: у БД лишився пароль від DB_PASSWORD на момент першого старту тома;
#   не копіюйте MYSQL_PASSWORD у DB_PASSWORD без ALTER USER у MySQL (скрипт: docker/scripts/canonicalize-…).
# • Не дублюйте DB_PASSWORD двома рядками в одному файлі (переможе останній).
# • MYSQL_ROOT_PASSWORD — окремо: це пароль root у MySQL (бекапи), не той самий, що DB_PASSWORD.
# • REDIS_PASSWORD у проді має бути непорожнім; REDIS_* для Laravel узгоджуйте з ним.
# • Генерація: openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 40
# • Ротація: ./docker/rotate-mysql-passwords.sh
# =============================================================================
#
#   cp docker/production.env.example docker/production.env
#
# Docker Compose: docker compose --env-file docker/production.env -f docker/compose.yaml …
# Laravel: ln -sf ../docker/production.env backend/.env
#
# Зворотна сумісність: якщо лишили лише MYSQL_USER / MYSQL_DATABASE / MYSQL_PASSWORD (без DB_*),
# compose все одно їх підхопить, поки не задано DB_*.

# --- MySQL root (лише для образу + mysqldump у бекапі; ≠ користувач додатку) ---
MYSQL_ROOT_PASSWORD=

# --- Redis ---
REDIS_PASSWORD=

# --- Доступ Laravel (і той самий не-root юзер у контейнері MySQL) ---
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=redpanda
DB_USERNAME=redpanda
DB_PASSWORD=

# Не задавайте MYSQL_PASSWORD, якщо вже є DB_PASSWORD — це legacy-фолбек у compose, не «другий пароль».
# MYSQL_PASSWORD=

# --- Laravel / Vite (решта з backend/.env.example за потреби) ---
APP_NAME=Redpanda
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

TRUSTED_PROXIES=127.0.0.1

# Sanctum SPA: хост із APP_URL автоматично додається до stateful-доменів (AppServiceProvider).
# Розкоментуйте лише якщо потрібні додаткові хости (через кому, без https://):
# SANCTUM_STATEFUL_DOMAINS=preview.example.com,localhost

APP_LOCALE=uk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=uk_UA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_HTTP_SUMMARY=false
HEALTH_CHECK_REDIS=false

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
# Порт процесу Reverb (усередині контейнера). Має збігатися з REVERB_SERVER_PORT у docker/compose.yaml
# і з тим, що потрапляє в config cache після `php artisan optimize` (контейнер php).
REVERB_SERVER_PORT=6001
# PHP → Reverb (усередині Docker-мережі). Не localhost — інакше broadcast з Laravel не потрапить на WS-сервер.
REVERB_HOST=reverb
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# Браузер → Reverb (TLS і шлях /app на хостовому nginx). Не підставляйте REVERB_HOST=reverb сюди.
# Якщо залишити порожнім або лишити ${REVERB_HOST} без розгортання — vite.config.js підставить host/port/scheme з APP_URL.
VITE_REVERB_HOST=
VITE_REVERB_PORT=
VITE_REVERB_SCHEME=
