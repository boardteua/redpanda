# =============================================================================
# ПРОДАКШЕН — мінімальна безпека (обов’язково прочитайте перед заповненням)
# =============================================================================
# • Не комітьте цей файл з реальними значеннями. Копія: docker/production.env (у .gitignore).
# • MYSQL_ROOT_PASSWORD, MYSQL_PASSWORD, REDIS_PASSWORD — унікальні, довгі (рекоменд. ≥24 символів).
#   Генерація: openssl rand -base64 32 | tr -dc 'A-Za-z0-9' | head -c 40
# • У проді не використовуйте дефолти з compose.yaml (root/redpanda, Redis без пароля).
# • REDIS_PASSWORD у проді має бути непорожнім — інакше Redis доступний лише з мережі Docker, але без auth.
# • TRUSTED_PROXIES: перелік IP вашого reverse proxy (nginx на хості), не використовуйте * без крайньої потреби.
# • APP_DEBUG=false, APP_ENV=production — завжди на проді.
# • Ротація паролів при існуючому томі MySQL: ./docker/rotate-mysql-passwords.sh (див. коментарі в скрипті) + оновлення цього файлу.
# =============================================================================
#
#   cp docker/production.env.example docker/production.env
#
# Docker Compose: інтерполяція `${VAR}` у docker/compose.yaml через
#   docker compose --env-file docker/production.env -f docker/compose.yaml …
# Плюс опційне підвантаження цього ж файлу в контейнери php/queue/reverb (env_file required: false).
#
# Laravel: рекомендовано один файл на диску для PHP-контейнера та artisan на хості:
#   ln -sf ../docker/production.env backend/.env
# (з каталогу backend/; або з кореня репо: ln -sf docker/production.env backend/.env)
#
# Якщо `.env` не створювати: змінні з `env_file` у сервісах `php` / `queue` / `reverb` уже в процесі;
# Laravel не перезаписує наявні змінні середовища значеннями з файлу `.env` (immutable Dotenv).
#
# Повні коментарі та додаткові ключі — у backend/.env.example.
# Узгодження: DB_PASSWORD = MYSQL_PASSWORD; REDIS_PASSWORD — один для Redis і Laravel (у контейнері DB_PASSWORD також береться з MYSQL_PASSWORD через compose).

# --- Docker Compose (інтерполяція + контейнери mysql/redis) ---
MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
REDIS_PASSWORD=

# --- Laravel / Vite (обов’язкові для продакшену; доповніть з backend/.env.example) ---
APP_NAME=Redpanda
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com

# IP хостового nginx (або docker bridge до проксі), через кому. Уникайте TRUSTED_PROXIES=* у проді.
TRUSTED_PROXIES=127.0.0.1

SANCTUM_STATEFUL_DOMAINS=example.com

APP_LOCALE=uk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=uk_UA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_HTTP_SUMMARY=false
HEALTH_CHECK_REDIS=false

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=redpanda
DB_USERNAME=redpanda
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
