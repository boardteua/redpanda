# Скопіюйте на сервері (не комітити):
#   cp docker/compose.deploy.env.example docker/compose.deploy.env
# Згенеруйте свої значення, напр.:
#   openssl rand -base64 32
#   openssl rand -base64 24
#
# У backend/.env мають збігатися:
#   DB_USERNAME=redpanda
#   DB_PASSWORD=<те саме, що MYSQL_PASSWORD нижче>
#   REDIS_PASSWORD=<те саме, що REDIS_PASSWORD нижче>
#
# Якщо том mysql_data уже ініціалізований зі старими паролями — змініть паролі в MySQL вручну
# або видаліть том (втрата даних) перед першим up з новими значеннями.

MYSQL_ROOT_PASSWORD=
MYSQL_PASSWORD=
REDIS_PASSWORD=
