# Legacy: мінімальний --env-file для Compose (без повного Laravel-набору).
# Канон — docker/production.env.example (DB_* для юзера додатку + MYSQL_ROOT_PASSWORD).
#
# Рекомендовано (один канон з Laravel):
#   DB_DATABASE=redpanda
#   DB_USERNAME=redpanda
#   DB_PASSWORD=
#   MYSQL_ROOT_PASSWORD=
#
# Старий варіант (compose підхопить, якщо DB_PASSWORD не задано):
#   MYSQL_PASSWORD=

MYSQL_ROOT_PASSWORD=
DB_DATABASE=redpanda
DB_USERNAME=redpanda
DB_PASSWORD=
REDIS_PASSWORD=
