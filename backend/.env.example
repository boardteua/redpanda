APP_NAME=Redpanda
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# За балансувальником / reverse proxy: IP проксі через кому, або * (лише якщо свідомо приймаєте ризики підробки X-Forwarded-*).
# Без цього Laravel не довіряє forwarded headers — `request->ip()` і бан по IP залежать від прямого з’єднання.
# TRUSTED_PROXIES=10.0.0.1,10.0.0.2

# Домени SPA для Sanctum (cookie + сесія на /api/*). Для Vite dev часто: localhost,127.0.0.1,localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000

APP_LOCALE=uk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=uk_UA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Додайте structured до LOG_STACK (напр. single,structured) для JSON-рядків у storage/logs/structured.log
# LOG_HTTP_SUMMARY=true — один info-лог на запит (для демо; шумно)
LOG_HTTP_SUMMARY=false
# Примусово перевіряти Redis у GET /health/ready (інакше — лише якщо cache/queue на redis)
HEALTH_CHECK_REDIS=false

# MySQL (utf8mb4 у config/database.php за замовчуванням). Для швидких локальних тестів можна тимчасово: DB_CONNECTION=sqlite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=redpanda
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Чат: скільки годин після відправки звичайний користувач може редагувати власне публічне повідомлення (VIP — без обмеження; див. T36).
# CHAT_MESSAGE_EDIT_WINDOW_HOURS=24

CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Листи: log — у laravel.log; smtp — у локальний Mailpit (див. docker-compose.mailpit.yml, UI :8025).
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Для Mailpit/MailHog без TLS залиште порожнім (див. Laravel mail.md / Homestead Mailpit).
# MAIL_SCHEME=
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Laravel Reverb (згенеруйте унікальні значення: php artisan reverb:install)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Auth0 (T76): соціальний вхід OIDC + Universal Login; логін/пароль і гість лишаються в Laravel.
# AUTH0_ENABLED=false
# AUTH0_DOMAIN=your-tenant.eu.auth0.com
# AUTH0_AUDIENCE=https://your-api-identifier
# Той самий Client ID, що в SPA Application у Auth0 Dashboard (публічний; для опційної перевірки azp на API).
# AUTH0_SPA_CLIENT_ID=
# AUTH0_JWKS_CACHE_TTL=3600
