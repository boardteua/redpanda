APP_NAME=Redpanda
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Локально: пароль для db:seed користувача org100h (чат-адмін). Без змінної сидер org100h пропускається.
# ORG100H_SEED_PASSWORD=
# Має збігатися з URL SPA у браузері; з нього будується посилання в листі скидання пароля (T94).
# У проді за HTTPS обов’язково https://… — інакше @vite() / url() згенерують http:// (mixed content).
APP_URL=http://localhost

# Великі зображення в чаті (T86): `php artisan serve` підхоплює backend/php-ini.d через `composer dev` (scripts/run-dev.php).
# Якщо запускаєте лише `php artisan serve` — експортуйте PHP_INI_SCAN_DIR=шлях/backend/php-ini.d або підніміть ліміти в php.ini / Docker (docker compose --profile app).

# За балансувальником / reverse proxy: IP проксі через кому, або * (лише якщо свідомо приймаєте ризики підробки X-Forwarded-*).
# Без цього Laravel не довіряє forwarded headers — `request->ip()` і бан по IP залежать від прямого з’єднання.
# TRUSTED_PROXIES=10.0.0.1,10.0.0.2

# Домени SPA для Sanctum (cookie + сесія на /api/*). Обов’язково host:port як у браузері (docker nginx :8080, Vite :5173).
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,localhost:8080,127.0.0.1,127.0.0.1:5173,127.0.0.1:8080,127.0.0.1:8000

APP_LOCALE=uk
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=uk_UA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Додайте structured до LOG_STACK (напр. single,structured) для JSON-рядків у storage/logs/structured.log
# LOG_HTTP_SUMMARY=true — один info-лог на запит (для демо; шумно)
LOG_HTTP_SUMMARY=false
# Примусово перевіряти Redis у GET /health/ready (інакше — лише якщо cache/queue на redis)
HEALTH_CHECK_REDIS=false

# MySQL (utf8mb4 у config/database.php за замовчуванням). Для швидких локальних тестів можна тимчасово: DB_CONNECTION=sqlite
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=redpanda
DB_USERNAME=root
DB_PASSWORD=

# T13: окрема БД після `mysql … < org100h.sql` (дамп не в репо / без секретів у git). Якщо LEGACY_DB_DATABASE порожній — chat:legacy-* не працюють.
# SQL-шаблон: docs/chat-v2/T128-LEGACY-MYSQL-SETUP.md
# LEGACY_DB_HOST=127.0.0.1
# LEGACY_DB_PORT=3306
# LEGACY_DB_DATABASE=legacy_org100h
# LEGACY_DB_USERNAME=root
# LEGACY_DB_PASSWORD=

# T113: копіювання аватарок (rsync). На одному сервері — два абсолютні шляхи (без SSH у команді).
# Віддалене джерело: user@host:/var/www/board.te.ua/html/avatar/
# LEGACY_AVATAR_RSYNC_SOURCE=/var/www/board.te.ua/html/avatar/
# Призначення на хості (rsync): часто …/backend/storage/app/legacy-avatars
# LEGACY_AVATAR_RSYNC_DEST=/var/www/redpanda/backend/storage/app/legacy-avatars
# У Docker для chat:legacy-link-user-avatars: порожній DEST або /var/www/html/storage/app/legacy-avatars (див. T113).

# T132: uploads — так само: локальні шляхи або user@host:/path
# LEGACY_UPLOADS_RSYNC_SOURCE=/var/www/board.te.ua/html/uploads/
# LEGACY_UPLOADS_RSYNC_DEST=/var/www/redpanda/backend/storage/app/legacy-uploads

# T132: публічний origin нового сайту для заміни посилань board.te.ua у текстах (без завершального /)
# LEGACY_URL_REMAP_TARGET_ORIGIN=https://chat.example.com

SESSION_DRIVER=database
# T203: ~30 days idle (minutes); sliding with database driver — each request extends idle window.
# Shorter value in .env if policy requires (e.g. shared kiosks).
SESSION_LIFETIME=43200
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# T203: `lax` keeps CSRF-friendly defaults; top-level GET navigations (typical Web Push → URL)
# still send the session cookie. Use `none` + SESSION_SECURE_COOKIE=true only if a proven
# cross-site cookie issue remains (weaker third-party context).
# SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
# Черга broadcast (ShouldBroadcast): у проді зазвичай database/redis + worker; для локальної мінімальної затримки WS див. docs/chat-v2/T161-SLOW-NETWORK-SEND.md (P0-4).
QUEUE_CONNECTION=database

# Чат: дефолт годин для редагування/видалення власного публічного повідомлення (T36/T122).
# Після збереження значення в адмінці (PATCH /api/v1/chat/settings → message_edit_window_hours) воно в БД переважає над env; env лишається fallback, доки в БД null.
# VIP/staff — окремі правила. 0 у БД = нульове вікно (фактична заборона для звичайного юзера).
# CHAT_MESSAGE_EDIT_WINDOW_HOURS=24

# T149: системний бот «Руда панда» (опційно; інакше — після migrate + SystemBotUserSeeder)
# CHAT_SYSTEM_BOT_USER_ID=
# Кімната для оголошень про нову публічну кімнату (null = найменший публічний room_id)
# CHAT_BOT_ANNOUNCE_ROOM_ID=
# Дебаунс «зайшов у кімнату» (секунди)
CACHE_STORE=database

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Пошта: локально — log (у laravel.log) або smtp → Mailpit (backend/docker-compose.mailpit.yml, UI http://127.0.0.1:8025).
# Staging/production — Gmail або інший SMTP: docs/chat-v2/MAIL-SMTP.md (секрети лише в .env на сервері, не в git).
MAIL_MAILER=log

# Локально з Mailpit (plain SMTP, порт 1025)
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
# Не задавайте MAIL_SCHEME для Mailpit (Laravel 13 / Symfony Mailer: scheme залишається smtp).
# MAIL_SCHEME=

# Приклад Gmail SMTP (розкоментуйте на staging/production; пароль — лише Google App Password при увімкненій 2FA)
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your.address@gmail.com
# MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
# MAIL_FROM_ADDRESS=your.address@gmail.com
# MAIL_FROM_NAME="${APP_NAME}"
# Порт 587: TLS через STARTTLS (typical); порт 465 — smtps; деталі в MAIL-SMTP.md.
# У Laravel 13 немає MAIL_ENCRYPTION у стандартному config/mail.php — керування через порт / MAIL_SCHEME / MAIL_URL.

MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Laravel Reverb (згенеруйте унікальні значення: php artisan reverb:install)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
# Куди Laravel (PHP) шле broadcast: у Docker compose — ім’я сервісу (reverb), локально — localhost.
REVERB_HOST=localhost
# Порт процесу Reverb (у docker/compose.yaml app-профіль: 6001). Не плутати з HTTP (Nginx 8080 / публічний 443).
REVERB_PORT=6001
REVERB_SCHEME=http

VITE_APP_NAME="${APP_NAME}"
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# Куди браузер відкриває wss (після хостового nginx). У проді зазвичай той самий хост, що APP_URL, порт 443.
# Якщо змінні з ${…} не розгорнуті — vite.config.js підставить host/port/scheme з APP_URL.
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# Auth0 (T76): соціальний вхід OIDC + Universal Login; логін/пароль і гість лишаються в Laravel.
# AUTH0_ENABLED=false
# AUTH0_DOMAIN=your-tenant.eu.auth0.com
# AUTH0_AUDIENCE=https://your-api-identifier
# Той самий Client ID, що в SPA Application у Auth0 Dashboard (публічний; для опційної перевірки azp на API).
# AUTH0_SPA_CLIENT_ID=
# AUTH0_JWKS_CACHE_TTL=3600

# Web Push (T165): згенеруйте пару через `Minishlink\WebPush\VAPID::createVapidKeys()` або openssl, секрети — лише в .env на сервері.
# SUBJECT: `mailto:` або HTTPS origin вашого сайту; PUBLIC_KEY можна безпечно віддавати в SPA, PRIVATE_KEY — ніколи.
# WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com
# WEB_PUSH_VAPID_PUBLIC_KEY=
# WEB_PUSH_VAPID_PRIVATE_KEY=
# TTL у секундах (дефолт 300); urgency: very-low | low | normal | high
# WEB_PUSH_TTL=300
# WEB_PUSH_URGENCY=normal

# T175: proxycheck.io anti-spam / anti-ban-evasion (server-side)
# У проді ключ уже заданий на сервері — НЕ комітити реальний ключ у git.
PROXYCHECK_ENABLED=false
# PROXYCHECK_API_KEY=111111-222222-333333-444444
PROXYCHECK_TIMEOUT_MS=1500
PROXYCHECK_CACHE_TTL_SECONDS=600
PROXYCHECK_DENY_IF_PROXY_OR_VPN=true
PROXYCHECK_DENY_RISK_THRESHOLD=67

# T177+: Gemini Developer API (server-side)
# Ключ лише на сервері/.env, НІКОЛИ у фронтенд-асетах.
GEMINI_ENABLED=false
# GEMINI_API_KEY=your_api_key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_API_VERSION=v1beta
GEMINI_TIMEOUT_MS=8000
GEMINI_DEFAULT_MODEL=gemini-2.5-flash
# T180: ідентифікатори моделей за tier (порожній FLASH → береться GEMINI_DEFAULT_MODEL; порожній FLASH_LITE → FLASH)
# GEMINI_MODEL_FLASH_LITE=gemini-2.5-flash-lite-preview-06-17
# GEMINI_MODEL_FLASH=gemini-2.5-flash
# GEMINI_MODEL_PRO=gemini-2.5-pro
# GEMINI_MODEL_IMAGE=gemini-2.5-flash-image
# Опційно для VIP+complex→Pro: бюджет міркування (0 = вимкнено) або рівень для Gemini 3 (напр. low)
# GEMINI_PRO_THINKING_BUDGET=0
# GEMINI_PRO_THINKING_LEVEL=

# Dev: у відповіді POST /api/v1/rooms/…/messages додати meta.ruda_panda_llm_debug (класифікатор follow-up YES/NO тощо).
# Працює лише разом з APP_DEBUG=true або APP_ENV=local. На фронті лог у console лише в Vite dev (import.meta.env.DEV).
# CHAT_RUDA_PANDA_LLM_DEBUG_CONSOLE=false
